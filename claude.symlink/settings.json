{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "bash /Users/mattduck/.claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Bash(make fix)",
      "Read(/tmp/*)",
      "Bash(,wrap-message *)",
      "Bash(git diff *)",
      "Bash(git diff HEAD --stat && echo \"---\" && git diff HEAD)",
      "Bash(,wrap-message *| git commit *)",
      "Bash(git reset --soft *&& ,wrap-message *| git commit *)",
      "Bash(grep *)",
      "Bash(rg *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/terminal-notifier -message \"Waiting for input\" -title \"Claude Code\" -sender com.apple.Terminal"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
    "dfd@dfd": true
  },
  "extraKnownMarketplaces": {
    "dfd": {
      "source": {
        "source": "github",
        "repo": "mattduck/diffyduck"
      }
    }
  },
  "promptSuggestionEnabled": false,
  "voiceEnabled": true
}
